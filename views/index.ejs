<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
        <div class="h-screen w-full bg-zinc-900 p-10 text-white" >
            <div class="nav mb-10">
                <a class="text-blue-500" href="/read">Read Users</a>
            </div>
            <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>
            <form action="/create" method="post">
                <input class="px-5 py-2 border-2 border-zinc-800 outline-none rounded" type="text" name="name" placeholder="name">
              <input class="px-5 py-2 border-2 border-zinc-800 outline-none rounded" type="text" name="email" placeholder="email">
              <input class="px-5 py-2 border-2 border-zinc-800 outline-none rounded" type="text" name="image" placeholder="imageURL">
              <input class="px-5 py2 ml-3 text-xl bg-blue-500 rounded" type="submit" value="Create User">
            
            </form>
        </div>
</body>
</html>