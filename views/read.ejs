<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
        <div class="h-screen w-full bg-zinc-900 p-10 text-white" >
               <a class="text-blue-500 mt-3 mb-10" href="/">back to home</a>
         <h1 class>All users</h1>
         <div class="users flex gap-3 flexwrap">
          <% users.forEach(function(user){  %>
              <div class="user w-72 p-4 bg-zinc-800 rounded">
                <div class="w-full h-52 rounded-lg bg-zinc-500"> 
                    <img class="w-full h-full object-cover object-center" src= "<%= user.image %>" alt="">
                </div>
                <h3 class="text-xl mt-3 tracking-tighter"><%= user.name %></h3>
                <h5 class="text-zinc-500"> <%= user.email %></h5>
                <div class="flex gap-3 mt-10">
                    <a class="text-zinc-200" href="">Edit User</a>
                    <a class="text-red-500" href="">Delete User</a>
                </div>
           
            
         </div>
       <%   }) %>
        </div>
</body>
</html>